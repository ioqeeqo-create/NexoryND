{
    "name": "flow",
    "version": "2.9.4",
    "description": "Nexory — десктопный музыкальный плеер (репозиторий на GitHub: NexoryND).",
    "author": "ioqeeqo-create",
    "license": "MIT",
    "homepage": "https://github.com/ioqeeqo-create/NexoryND#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/ioqeeqo-create/NexoryND.git"
    },
    "main": "main.js",
    "scripts": {
        "merge-renderer": "node scripts/merge-renderer.js",
        "prestart": "node scripts/merge-renderer.js",
        "prebuild": "node scripts/merge-renderer.js",
        "start": "electron .",
        "start:vk-server": "node server/flow-vk-server.js",
        "social-server": "node server/flow-social-server.js",
        "mobile-gateway": "node server/flow-mobile-gateway.js",
        "test:gateway": "node scripts/test-flow-gateway.cjs",
        "social-migrate": "node server/migrate-supabase-export-to-sqlite.js",
        "build:yandex-helper": "dotnet publish tools/flow-yandex-helper -c Release -r win-x64 --self-contained false",
        "prepare:nexory-logo": "node scripts/prepare-nexory-logo.mjs",
        "build": "electron-builder",
        "prebuild:win": "node scripts/merge-renderer.js && node scripts/build-windows-icon.mjs",
        "build:win": "electron-builder --win",
        "release:win": "electron-builder --win --publish always",
        "publish:update:stable": "node scripts/publish-stable-update.cjs"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0",
        "png-to-ico": "^3.0.1",
        "sharp": "^0.34.5"
    },
    "build": {
        "appId": "flow.player",
        "productName": "Nexory",
        "asarUnpack": [
            "tools/**"
        ],
        "files": [
            "**/*",
            "!node_modules/.cache",
            "!dist",
            "!NexoryND/**"
        ],
        "win": {
            "executableName": "Nexory",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.ico"
        },
        "portable": {
            "artifactName": "${productName}-Portable.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Nexory",
            "uninstallDisplayName": "Nexory",
            "installerIcon": "assets/icon.ico",
            "uninstallerIcon": "assets/icon.ico",
            "include": "build/installer.nsh",
            "artifactName": "${productName}-Setup.${ext}"
        },
        "directories": {
            "output": "dist"
        },
        "publish": {
            "provider": "github",
            "owner": "ioqeeqo-create",
            "repo": "NexoryND"
        }
    },
    "dependencies": {
        "axios": "^1.15.0",
        "better-sqlite3": "^11.10.0",
        "cors": "^2.8.6",
        "discord-rpc": "^4.0.1",
        "express": "^4.22.1",
        "ws": "^8.20.0"
    }
}
