{
  "name": "flow",
  "version": "2.4.2",
  "description": "Flow — десктопный музыкальный плеер: поиск, плейлисты, SoundCloud, комнаты и персональная «Моя волна».",
  "author": "ioqeeqo-create",
  "license": "MIT",
  "homepage": "https://github.com/ioqeeqo-create/FlowPleerLoww#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ioqeeqo-create/FlowPleerLoww.git"
  },
  "main": "main.js",
  "scripts": {
    "merge-renderer": "node scripts/merge-renderer.js",
    "prestart": "node scripts/merge-renderer.js",
    "prebuild": "node scripts/merge-renderer.js",
    "start": "electron .",
    "start:vk-server": "node server/flow-vk-server.js",
    "social-server": "node server/flow-social-server.js",
    "social-migrate": "node server/migrate-supabase-export-to-sqlite.js",
    "build:yandex-helper": "dotnet publish tools/flow-yandex-helper -c Release -r win-x64 --self-contained false",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "flow.player",
    "productName": "Flow",
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Flow"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "axios": "^1.15.0",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.6",
    "discord-rpc": "^4.0.1",
    "express": "^4.22.1",
    "ws": "^8.20.0"
  }
}
